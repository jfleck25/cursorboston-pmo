# Database — REQUIRED for sign-in (Prisma adapter). The value MUST begin with:
#   postgresql://   or   postgres://
# (No jdbc: prefix, no bare host:port.) Supabase/Vercel dashboards give a string you can paste as-is.
#
# Local example:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/momentum?schema=public
DATABASE_URL=

# New or empty database (Vercel Postgres, etc.) — create tables, then seed cohort/week:
#   npx prisma db push
#   npm run db:seed

# Auth.js — required in production. Generate: `npx auth secret` or `openssl rand -base64 32`
# (Dev server uses an insecure placeholder if this is missing — set it for real OAuth sessions.)
AUTH_SECRET=

# GitHub OAuth App (Authorization callback: http://localhost:3000/api/auth/callback/github)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub App (org install) — server-only issue fetch for the slot machine / Phase 3.
# Create an app with Contents: Read, Issues: Read (metadata), install on your org, then set:
GITHUB_APP_ID=""
# PEM private key — in .env use literal newlines, or single line with \n escapes (Vercel-friendly).
GITHUB_APP_PRIVATE_KEY=""
# Numeric installation ID for the org (Settings → GitHub Apps → Your app → Installations).
GITHUB_APP_INSTALLATION_ID=""
# Comma-separated owner/repo pairs — only these repos are queried (defense in depth).
GITHUB_APP_REPO_ALLOWLIST="octokit/rest.js,vercel/next.js"
# Optional override (default: quick-win)
# GITHUB_APP_ISSUE_LABEL=quick-win

# OpenAI — slot machine `generateObject` (server-only). Required for live AI reels.
OPENAI_API_KEY=""
# Optional model id (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Upstash Redis — 5 slot LLM calls per user per rolling minute in production (required in prod).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Public URL for Discord embeds + deep links (optional; Vercel sets VERCEL_URL automatically).
# NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app

# Discord webhooks — server-only; rotate by swapping env in the host dashboard.
DISCORD_WEBHOOK_ROLL_URL=""
DISCORD_WEBHOOK_SHIP_URL=""

# --- Deploy / smoke (Vercel) ---
# Required: DATABASE_URL, AUTH_SECRET, GITHUB_CLIENT_ID/SECRET
# Slot + rate limits: OPENAI_API_KEY, UPSTASH_* (prod), GitHub App vars for Source reel
# Optional: DISCORD_WEBHOOK_* , NEXT_PUBLIC_APP_URL
# Smoke: sign-in → slot prefetch → save task → ship (streak weekday) → Friday upvote → Discord receives roll + ship payloads
